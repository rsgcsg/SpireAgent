{
  "name": "spireagent-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace entrypoint for Re-SpireAgent and the STS2 Live Gateway.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check": "npm --prefix Re-SpireAgent run check",
    "check:agent": "npm --prefix Re-SpireAgent run check",
    "test:agent": "npm --prefix Re-SpireAgent test",
    "build:agent": "npm --prefix Re-SpireAgent run build",
    "check:docs": "node tools/check-active-markdown-links.mjs && npm run check:connector-inventory && npm run check:connector-adaptation",
    "check:connector-inventory": "node tools/check-connector-operation-inventory.mjs",
    "check:connector-adaptation": "node tools/check-connector-adaptation-contracts.mjs",
    "check:connector-compatibility-fixtures": "node tools/test-connector-compatibility-grader.mjs",
    "audit:connector-compatibility": "node tools/run-connector-compatibility-audit.mjs"
  }
}
