# Copy this file to .env.local and put your own secrets there.
# Never commit .env.local.

# Required only for P8 DeepSeek shadow workspace calls.
STS2_DEEPSEEK_API_KEY=

# P8 shadow calls are opt-in and shadow-only by default.
STS2_P8_WORKSPACE_SHADOW=1
STS2_P8_WORKSPACE_CALL=1

# Governance profile records how budgets should be interpreted. It does not enable live behavior.
STS2_BUDGET_GOVERNANCE_PROFILE=shadow_exploration

# Conservative safety defaults.
STS2_P8_WORKSPACE_MAX_SHADOW_CALLS=1
# Backward-compatible alias: STS2_P8_MAX_SHADOW_CALLS=1
STS2_P8_WORKSPACE_SOFT_INPUT_TOKENS=8000
STS2_P8_WORKSPACE_HARD_INPUT_TOKENS=12000
STS2_P8_WORKSPACE_ABLATION_MODE=full
STS2_DEEPSEEK_MAX_OUTPUT_TOKENS=400
STS2_DEEPSEEK_TIMEOUT_MS=25000
STS2_DEEPSEEK_RETRY_LIMIT=0
STS2_DEEPSEEK_EMPTY_RETRY_LIMIT=1
STS2_DEEPSEEK_TRUNCATION_RETRY_LIMIT=1
STS2_DEEPSEEK_OUTPUT_MODE=json_mode
STS2_DEEPSEEK_TEMPERATURE=0
STS2_DEEPSEEK_TOP_P=0.1
# Optional provider-contract experiment. Leave unset to keep DeepSeek's default thinking mode.
# STS2_DEEPSEEK_THINKING_MODE=disabled
# Rescue-only recovery defaults for `finish_reason=length` / empty-content cases.
# STS2_DEEPSEEK_RESCUE_THINKING_MODE=disabled
# STS2_DEEPSEEK_TRUNCATION_RESCUE_MAX_OUTPUT_TOKENS=256
# STS2_DEEPSEEK_EMPTY_RESCUE_MAX_OUTPUT_TOKENS=320
STS2_P8_WORKSPACE_MAX_ESTIMATED_COST_USD=0.05

# P8.5 live additive controls.
# Default remains off in the public template. The first approved live slice is combat-only.
STS2_P8_LIVE_ADDITIVE=1
STS2_P8_LIVE_DECISION_CLASSES=combat:llm_required

# Optional overrides.
# STS2_DEEPSEEK_MODEL=deepseek-v4-flash
# STS2_DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
