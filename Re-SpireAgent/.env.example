# STS2 MCP REST adapter
STS2_API_URL=http://localhost:15526
STS2_MCP_TIMEOUT_MS=5000

# DeepSeek. Keep the real key in .env.local only.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=30000
DEEPSEEK_MAX_OUTPUT_TOKENS=320
DEEPSEEK_THINKING_MODE=disabled

# Runtime and evidence
AGENT_DATA_DIR=data/runs
AGENT_MAX_TICKS=100
AGENT_TICK_DELAY_MS=250
AGENT_SETTLEMENT_POLL_MS=150
AGENT_SETTLEMENT_TIMEOUT_MS=3000
AGENT_END_TURN_SETTLEMENT_TIMEOUT_MS=8000
