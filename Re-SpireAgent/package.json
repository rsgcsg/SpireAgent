{
  "name": "re-spire-agent",
  "version": "0.1.0",
  "description": "A minimal, auditable Slay the Spire 2 DeepSeek agent runtime.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm run test && npm run build",
    "agent:inspect": "tsx src/app/main.ts inspect",
    "agent:connector-canary": "tsx src/app/main.ts connector-canary",
    "agent:tick": "tsx src/app/main.ts tick",
    "agent:run": "tsx src/app/main.ts run",
    "agent:replay": "tsx src/app/main.ts replay",
    "agent:prompt-audit": "tsx src/app/main.ts prompt-audit",
    "agent:prompt-shadow-compare": "tsx src/app/main.ts prompt-shadow-compare",
    "agent:prompt-repeat-baseline": "tsx src/app/main.ts prompt-repeat-baseline"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.14",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
